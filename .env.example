# LLM Provider: "groq" or "openai"
LLM_PROVIDER=groq

# Groq
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=qwen/qwen3-32b

# OpenAI (fallback)
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Auth — Upstash Redis (free: https://upstash.com)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# Auth — Resend email (free: https://resend.com)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=ProBrief <noreply@singularity-society.com>

# Auth — JWT secret (change to a random string)
AUTH_SECRET=change-me-to-random-string

# Quota
MAX_FREE_USES=3
